DATABASE_URL="postgresql://USER:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"
# Vercel Preview runs with CI=1, so `scripts/vercel-build.mjs` skips `prisma migrate deploy` unless you set:
# VERCEL_RUN_MIGRATIONS=1
# (Requires DIRECT_URL on the host.) Keeps preview DB schema in sync after new migrations.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
ANTHROPIC_API_KEY=""
# Set to "true" to enable Ask Keel + Capture AI (requires ANTHROPIC_API_KEY).
KEEL_AI_ENABLED="false"
# Per-user daily ceiling for estimated AI spend (AUD cents). Ask + Capture share this bucket.
KEEL_AI_COST_CEILING_CENTS_AUD="50"
BANK_ENCRYPTION_KEY=""

# Up Bank PAT (server-only) for `/spend/up` sync + `/api/up/sync`.
KEEL_UP_BANK_TOKEN=""
# Shared secret for `/api/up/webhook` (`x-keel-webhook-secret` header).
KEEL_UP_WEBHOOK_SECRET=""
# Vercel Cron: `Authorization: Bearer <CRON_SECRET>` for `/api/cron/daily-alerts`.
CRON_SECRET=""
