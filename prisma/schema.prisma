// Keel2 Postgres schema (Supabase-hosted). Multi-tenant via Budget + BudgetMember;
// all domain tables carry `budgetId` (or inherit through relations) for isolation.
// Spend + wealth modules extend the core commitments/incomes model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships BudgetMember[]
  invites     BudgetInvite[] @relation("InvitedByUser")
}

model Budget {
  id          String    @id @default(cuid())
  name        String
  bankBalance Decimal   @default(0)
  balanceAsOf DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members        BudgetMember[]
  invites        BudgetInvite[]
  incomes        Income[]
  commitments    Commitment[]
  goals          Goal[]
  wealthAccounts WealthAccount[]
  wealthHoldings WealthHolding[]
  wealthSnapshots WealthSnapshot[]
  categories     Category[]
  spendAccounts     SpendAccount[]
  spendImportBatches SpendImportBatch[]
  spendTransactions  SpendTransaction[]
  commitmentSkips    CommitmentSkip[]
  goalSkips          GoalSkip[]
}

model BudgetMember {
  id        String   @id @default(cuid())
  budgetId  String
  userId    String
  role      String   @default("owner")
  createdAt DateTime @default(now())

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([budgetId, userId])
}

model BudgetInvite {
  id              String    @id @default(cuid())
  budgetId        String
  budget          Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  email           String
  token           String    @unique
  invitedByUserId String
  invitedByUser   User      @relation("InvitedByUser", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedAt      DateTime?
  createdAt       DateTime  @default(now())
}

model Income {
  id          String    @id @default(cuid())
  budgetId    String
  budget      Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  name        String
  amount      Decimal
  frequency   String
  nextPayDate DateTime
  isPrimary   Boolean   @default(false)
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  versions    IncomeVersion[]
  commitments Commitment[] @relation("IncomeCommitments")
  goals       Goal[]       @relation("IncomeGoals")
}

model IncomeVersion {
  id            String    @id @default(cuid())
  incomeId      String
  income        Income    @relation(fields: [incomeId], references: [id], onDelete: Cascade)
  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date
  name          String
  amount        Decimal
  frequency     String
  nextPayDate   DateTime
  createdAt     DateTime  @default(now())

  @@index([incomeId, effectiveFrom])
}

model Commitment {
  id               String       @id @default(cuid())
  budgetId         String
  budget           Budget       @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  fundedByIncomeId String?
  fundedByIncome   Income?      @relation("IncomeCommitments", fields: [fundedByIncomeId], references: [id], onDelete: SetNull)
  categoryId       String
  categoryRef      Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subcategoryId    String?
  subcategoryRef   Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  name             String
  amount           Decimal
  frequency        String
  nextDueDate      DateTime
  isPaused         Boolean      @default(false)
  archivedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  versions         CommitmentVersion[]
  spendTransactions SpendTransaction[]
  skips            CommitmentSkip[]

  @@index([budgetId, archivedAt])
}

model CommitmentVersion {
  id             String    @id @default(cuid())
  commitmentId   String
  commitment     Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
  effectiveFrom  DateTime  @db.Date
  effectiveTo    DateTime? @db.Date
  name           String
  amount         Decimal
  frequency      String
  nextDueDate    DateTime
  categoryId     String
  subcategoryId  String?
  fundedByIncomeId String?
  createdAt      DateTime  @default(now())

  @@index([commitmentId, effectiveFrom])
}

model Category {
  id        String   @id @default(cuid())
  budgetId  String
  budget    Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcategories Subcategory[]
  commitments   Commitment[]
  spendTransactions SpendTransaction[]

  @@unique([budgetId, name])
  @@index([budgetId])
}

model Subcategory {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  commitments Commitment[]
  spendTransactions SpendTransaction[]

  @@unique([categoryId, name])
  @@index([categoryId])
}

model Goal {
  id                 String    @id @default(cuid())
  budgetId           String
  budget             Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  fundedByIncomeId   String?
  fundedByIncome     Income?   @relation("IncomeGoals", fields: [fundedByIncomeId], references: [id], onDelete: SetNull)
  name               String
  contributionPerPay Decimal
  targetAmount       Decimal?
  targetDate         DateTime?
  currentBalance     Decimal   @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  skips GoalSkip[]
}

model CommitmentSkip {
  id              String    @id @default(cuid())
  budgetId        String
  commitmentId    String
  originalDate    DateTime  @db.Date
  strategy        String
  spreadOverN     Int?
  redirectTo      String?
  skippedAmount   Decimal?
  notes           String?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  createdByUserId String

  budget     Budget     @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  commitment Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)

  @@unique([commitmentId, originalDate])
  @@index([budgetId, revokedAt])
  @@index([budgetId])
}

model GoalSkip {
  id              String    @id @default(cuid())
  budgetId        String
  goalId          String
  originalDate    DateTime  @db.Date
  strategy        String
  notes           String?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  createdByUserId String

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  goal   Goal   @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, originalDate])
  @@index([budgetId, revokedAt])
  @@index([budgetId])
}

model WealthAccount {
  id        String   @id @default(cuid())
  budgetId  String
  budget    Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  name      String
  type      String   @default("OTHER")
  currency  String   @default("AUD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  holdings WealthHolding[]

  @@unique([budgetId, name])
  @@index([budgetId])
}

model WealthHolding {
  id            String        @id @default(cuid())
  budgetId      String
  budget        Budget        @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  accountId     String
  account       WealthAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  assetType     String
  symbol        String?
  name          String
  quantity      Decimal       @default(0)
  unitPrice     Decimal?
  valueOverride Decimal?
  asOf          DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([budgetId])
  @@index([accountId])
}

model WealthSnapshot {
  id         String   @id @default(cuid())
  budgetId   String
  budget     Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  recordedAt DateTime @db.Date
  totalValue Decimal
  createdAt  DateTime @default(now())

  @@index([budgetId, recordedAt])
}

model SpendAccount {
  id        String   @id @default(cuid())
  budgetId  String
  budget    Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  name      String
  bankName  String?
  bsb       String?
  accountName String?
  accountNumberEnc String?
  accountNumberIv  String?
  accountNumberLastFour String?
  currency  String   @default("AUD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions SpendTransaction[]
  importBatches SpendImportBatch[]

  @@index([budgetId])
}

model SpendImportBatch {
  id        String   @id @default(cuid())
  budgetId  String
  budget    Budget        @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  accountId String
  account   SpendAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  filename  String?
  rowCount  Int           @default(0)
  createdAt DateTime      @default(now())

  transactions SpendTransaction[]

  @@index([budgetId])
  @@index([accountId])
}

model AiRateLimit {
  userId      String   @id
  windowStart DateTime
  calls       Int      @default(0)
}

model SpendTransaction {
  id            String    @id @default(cuid())
  budgetId      String
  budget        Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  accountId     String
  account       SpendAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  importBatchId String?
  importBatch   SpendImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  postedOn      DateTime  @db.Date
  amount        Decimal
  memo          String
  dedupeKey     String
  categoryId    String?
  categoryRef   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategoryId String?
  subcategoryRef Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  commitmentId  String?
  commitment    Commitment? @relation(fields: [commitmentId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([budgetId, dedupeKey])
  @@index([budgetId, postedOn])
  @@index([accountId, postedOn])
}
